# SupportGenie environment template
# Copy this file to .env and fill in only the provider you want to use.

# -----------------------------
# Provider option 1: OpenAI
# -----------------------------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=

# -----------------------------
# Provider option 2: Gemini
# -----------------------------
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3-flash-review

# -----------------------------
# Optional: OpenAI-compatible providers
# Examples: Groq, Ollama, etc.
# -----------------------------
# OPENAI_API_KEY=
# OPENAI_BASE_URL=
# OPENAI_MODEL=
